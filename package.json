{
  "name": "@ftdigital/atomic",
  "version": "0.0.45",
  "description": "",
  "author": "FT Digital",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ftdigital/atomic.git"
  },
  "bugs": {
    "url": "https://github.com/ftdigital/atomic/issues"
  },
  "license": "MIT",
  "main": "./dist/atomic.umd.cjs",
  "module": "./dist/atomic.es.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "private": false,
  "files": [
    "package.json",
    "dist",
    "bin"
  ],
  "exports": {
    ".": {
      "import": "./dist/atomic.es.mjs",
      "types": "./dist/index.d.ts",
      "require": "./dist/atomic.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "jest",
    "test:dev": "yarn test --watch"
  },
  "bin": {
    "atomic": "./bin/cli.mjs"
  },
  "size-limit": [
    {
      "path": "dist/atomic.es.mjs",
      "limit": "10 KB"
    },
    {
      "path": "dist/atomic.umd.cjs",
      "limit": "10 KB"
    }
  ],
  "peerDependencies": {
    "tsx": ">=4.0.0"
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.4",
    "vite": "^5.2.8",
    "vite-plugin-dts": "^3.8.1",
    "vite-tsconfig-paths": "^4.3.2"
  }
}
